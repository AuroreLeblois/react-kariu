{
  "name": "react_kariu",
  "version": "1.0.0",
  "description": "react library for react",
  "author": "Aurore Leblois",
  "copyright": "Copyright © year ${author}",
  "main": "build/index.js",
  "scripts": {
    "start": "start-storybook --quiet --ci --port 9999 && start http://localhost:9999",
    "web": "npm start",
    "build:svg": "svgr --icon --svg-props direction={props.direction} --svg-props color={props.color} --replace-attr-values currentColor={props.color} --svg-props animation={props.animation}  src/elements/icon/svg -d src/elements/icon/components --ignore-existing",
    "build-storybook": "build-storybook -o build --quiet",
    "build-docs": "build-storybook -o build_docs --quiet --docs",
    "build": "rollup -c",
    "chromatic": "npx chromatic --project-token b47fc4262037"
  },
  "repository": {
    "type": "git",
    "url": "react_kariu"
  },
  "keywords": [
    "library",
    "component",
    "react"
  ],
  "license": "ISC",
  "dependencies": {
    "@babel/plugin-syntax-jsx": "^7.14.5",
    "@babel/plugin-transform-runtime": "^7.14.5",
    "@emotion/css": "^11.1.3",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-commonjs": "^19.0.0",
    "@rollup/plugin-node-resolve": "^13.0.0",
    "@rollup/plugin-typescript": "^8.2.1",
    "@rollup/plugin-url": "^6.0.0",
    "@storybook/addons": "^6.3.0",
    "@storybook/theming": "^6.3.0",
    "@svgr/rollup": "^5.5.0",
    "cool-ascii-faces": "^1.3.4",
    "leaflet": "^1.7.1",
    "node": "^15.14.0",
    "postcss": "^8.3.5",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-scripts": "^4.0.3",
    "rollup": "^2.52.6",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.0",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.30.0",
    "typescript": "^4.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@storybook/addon-actions": "^6.3.0",
    "@storybook/addon-essentials": "^6.3.0",
    "@storybook/addon-links": "^6.3.0",
    "@storybook/react": "^6.3.0",
    "@svgr/cli": "^5.5.0",
    "babel-loader": "^8.2.2",
    "chromatic": "^5.9.2"
  }
}
